# Telegram
TELEGRAM_BOT_TOKEN=

# The client appends /mcp exactly once. Set this to the raw deployed service URL.
MCP_SERVER_URL=https://mcp-462651960530.europe-west1.run.app
MCP_AUTH_TOKEN=
MCP_TIMEOUT_MS=15000

# Electron Hub uses an OpenAI-compatible chat completions endpoint.
# Set the provider base URL, normally ending in /v1.
ELECTRON_HUB_API_KEY=
ELECTRON_HUB_BASE_URL=
ELECTRON_HUB_MODEL=gpt-4o

# Official Google Gen AI fallback provider.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Financial context and local session settings.
ADVISOR_CURRENCY=NGN
STATEMENT_LIMIT=100
SESSION_HISTORY_LIMIT=6
